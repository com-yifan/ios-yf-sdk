
platform :ios, '11.0'
source 'https://github.com/CocoaPods/Specs.git'
target 'YFAdsSDK_Example' do
  
  # TSSPSDK【必须】
  pod 'TSSPSDK', '6.1.2.1'
  #  百度【必须】
  pod 'BaiduMobAdSDK','10.050'
  # 优量汇【必须】
  pod 'GDTMobSDK' ,'4.15.90'
  # 京东【必须】
  pod 'JADYun', '2.6.8'
  pod 'JADYunMotion', '2.6.8'  #京东摇一摇组件
  #  穿山甲【必须】注意：穿山甲70xx版本运行环境配置发生变更，支持系统iOS 13.0及以上版本，请Xcode修改项目支持最低13.0，如需支持13.0以下请联系技术同学获取支持的穿山甲版本
  pod 'Ads-CN', '7.6.0.4', :subspecs => ['BUAdSDK','CSJMediation','BUAdLive-Framework']
  # Gromore-Adn适配器
  pod 'GMBaiduAdapter', '10.050.0'
  pod 'GMGdtAdapter', '4.15.80.0'
  pod 'GMKsAdapter', '5.3.20.1.0'
  # 快手【必须】
  pod 'KSAdSDK','5.4.10.1'
  pod 'WechatOpenSDK'
 
 # Demo依赖库
  pod 'AFNetworking'
  pod 'Bugly'
  pod 'SDWebImage','5.18.0'
  pod 'Masonry'
  pod "STDebugConsole"
  pod 'JPFPSStatus'
  pod 'YYKit'
  #pod 'FLAnimatedImage'
  pod 'MJRefresh'
  
  
  target 'YFAdsSDK_Tests' do
    inherit! :search_paths
  end

  post_install do |installer|
  installer.pods_project.build_configurations.each do |config|
    config.build_settings["EXCLUDED_ARCHS[sdk=iphonesimulator*]"] = "arm64"
    end
  end
  
end
